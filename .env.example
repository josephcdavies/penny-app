# ── Server ──────────────────────────────────────────────────────────────────

# Port the Express server listens on (default: 3001, no need to change for Docker)
PORT=3001

# Secret used to sign JWTs — keep it private
# Optional: auto-generated on first run if left blank
# Set explicitly to ensure tokens survive server restarts in production
JWT_SECRET=

# Base URL where the app is served — used in magic links sent via Slack
# For local dev: http://localhost:3001
# For Docker:    http://localhost  (or your server's domain/IP)
APP_URL=http://localhost

# ── Slack (optional) ────────────────────────────────────────────────────────

# Incoming Webhook URL for Slack notifications
# Leave blank to disable — the app works fully without it
# Setup: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
